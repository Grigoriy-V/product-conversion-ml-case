{
  "schema_vocabulary": "bundled-classical-v2",
  "contract_note": "Machine-readable contract description only. tools/experiment_ledger.py authoritatively enforces the exact closed and conditional rules; this project does not claim a complete JSON Schema Draft implementation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "timestamp_utc",
    "experiment_id",
    "operation",
    "status",
    "commands",
    "runtime",
    "dataset",
    "leakage_audit",
    "split",
    "features",
    "pipeline",
    "baseline_cv",
    "calibration",
    "threshold",
    "artifacts",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "timestamp_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "experiment_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,127}$"
    },
    "operation": {
      "enum": [
        "dataset_audit",
        "baseline",
        "evaluation",
        "closeout"
      ]
    },
    "status": {
      "enum": [
        "completed",
        "failed",
        "skipped",
        "pending"
      ]
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "runtime": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/runtime"
        }
      ]
    },
    "dataset": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/dataset"
        }
      ]
    },
    "leakage_audit": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/leakage_audit"
        }
      ]
    },
    "split": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/split"
        }
      ]
    },
    "features": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/features"
        }
      ]
    },
    "pipeline": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/pipeline"
        }
      ]
    },
    "baseline_cv": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/baseline_cv"
        }
      ]
    },
    "calibration": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/calibration"
        }
      ]
    },
    "threshold": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/threshold"
        }
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "decision": {
      "$ref": "#/$defs/decision"
    }
  },
  "$defs": {
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "python_version",
        "platform",
        "executor",
        "packages"
      ],
      "properties": {
        "python_version": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "executor": {
          "type": "string",
          "minLength": 1
        },
        "packages": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source",
        "license",
        "fingerprint_sha256",
        "target"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "license": {
          "type": "string",
          "minLength": 1
        },
        "fingerprint_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "target": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "column",
            "task_type",
            "positive_class"
          ],
          "properties": {
            "column": {
              "type": "string",
              "minLength": 1
            },
            "task_type": {
              "const": "binary_classification"
            },
            "positive_class": {
              "type": [
                "string",
                "integer"
              ]
            }
          }
        }
      }
    },
    "leakage_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "checked",
        "methods",
        "findings",
        "prohibited_features"
      ],
      "properties": {
        "checked": {
          "const": true
        },
        "methods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "prohibited_features": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "split": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "random_state",
        "stratified",
        "stratify_by",
        "train_fingerprint_sha256",
        "test_fingerprint_sha256"
      ],
      "properties": {
        "strategy": {
          "enum": [
            "random",
            "temporal",
            "group"
          ]
        },
        "random_state": {
          "type": [
            "integer",
            "null"
          ]
        },
        "stratified": {
          "type": "boolean"
        },
        "stratify_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "train_fingerprint_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "test_fingerprint_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "included",
        "categorical",
        "numeric",
        "excluded"
      ],
      "properties": {
        "included": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "categorical": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "numeric": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excluded": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "library",
        "class",
        "steps"
      ],
      "properties": {
        "library": {
          "const": "sklearn"
        },
        "class": {
          "const": "sklearn.pipeline.Pipeline"
        },
        "steps": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "class",
              "params"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "class": {
                "type": "string",
                "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
              },
              "params": {
                "type": "object",
                "minProperties": 1
              }
            }
          }
        }
      }
    },
    "baseline_cv": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "baseline_model",
        "cv",
        "metrics",
        "primary_metric"
      ],
      "properties": {
        "baseline_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "class",
            "params"
          ],
          "properties": {
            "class": {
              "type": "string",
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)+$"
            },
            "params": {
              "type": "object",
              "minProperties": 1
            }
          }
        },
        "cv": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "strategy",
            "folds",
            "shuffle",
            "random_state"
          ],
          "properties": {
            "strategy": {
              "enum": [
                "StratifiedKFold",
                "GroupKFold",
                "TimeSeriesSplit"
              ]
            },
            "folds": {
              "type": "integer",
              "minimum": 2,
              "maximum": 20
            },
            "shuffle": {
              "type": "boolean"
            },
            "random_state": {
              "type": [
                "integer",
                "null"
              ]
            }
          }
        },
        "metrics": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "number"
          }
        },
        "primary_metric": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "cv_folds",
        "metrics_before",
        "metrics_after"
      ],
      "properties": {
        "method": {
          "enum": [
            "sigmoid",
            "isotonic",
            "none"
          ]
        },
        "cv_folds": {
          "type": "integer",
          "minimum": 2,
          "maximum": 20
        },
        "metrics_before": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "number"
          }
        },
        "metrics_after": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },
    "threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "objective",
        "selection_split",
        "metric_name",
        "metric_value"
      ],
      "properties": {
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "objective": {
          "type": "string",
          "minLength": 1
        },
        "selection_split": {
          "enum": [
            "validation",
            "train_cv_oof"
          ]
        },
        "metric_name": {
          "type": "string",
          "minLength": 1
        },
        "metric_value": {
          "type": "number"
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "rationale"
      ],
      "properties": {
        "action": {
          "enum": [
            "continue",
            "stop",
            "change",
            "freeze",
            "pending"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "conditional_contracts": {
    "completed": "commands and runtime are non-empty; dataset is strict; operation-specific evidence is required and irrelevant evidence is null",
    "failed": "commands and runtime describe the failed attempt; all result-bearing fields are null and artifacts are empty",
    "pending_or_skipped": "commands are empty, runtime and result-bearing fields are null, and artifacts are empty",
    "lifecycle": "dataset_audit precedes baseline, baseline precedes evaluation, closeout is terminal; pending must resolve in place",
    "identity": "completed events for one experiment_id retain byte-equivalent dataset identity"
  }
}
